<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppThemeAmoled" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">#000000</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:textColorPrimary">#ffffff</item>
        <item name="android:textColorSecondary">#a9a9a9</item>
        <item name="android:colorAccent">#adff2f</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowActionModeOverlay">false</item>
        <item name="android:actionBarStyle">@style/AppActionBarAmoled</item>
    </style>
    <style name="AppThemeDark" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">#121212</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:textColorPrimary">#ffffff</item>
        <item name="android:textColorSecondary">#b0b0b0</item>
        <item name="android:colorAccent">#adff2f</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowActionModeOverlay">false</item>
        <item name="android:actionBarStyle">@style/AppActionBarDark</item>
    </style>
    <style name="AppThemeWhite" parent="@android:style/Theme.DeviceDefault.Light">
        <item name="android:windowBackground">#ffffff</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:textColorPrimary">#111111</item>
        <item name="android:textColorSecondary">#666666</item>
        <item name="android:colorAccent">#3f6f00</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#ffffff</item>
        <item name="android:statusBarColor">#ffffff</item>
        <item name="android:windowActionModeOverlay">false</item>
        <item name="android:actionBarStyle">@style/AppActionBarWhite</item>
    </style>
    <style name="AppActionBarAmoled" parent="@android:style/Widget.Material.ActionBar.Solid">
        <item name="android:background">#000000</item>
        <item name="android:titleTextStyle">@style/AppActionBarTitleDark</item>
    </style>
    <style name="AppActionBarDark" parent="@android:style/Widget.Material.ActionBar.Solid">
        <item name="android:background">#121212</item>
        <item name="android:titleTextStyle">@style/AppActionBarTitleDark</item>
    </style>
    <style name="AppActionBarWhite" parent="@android:style/Widget.Material.ActionBar.Solid">
        <item name="android:background">#ffffff</item>
        <item name="android:titleTextStyle">@style/AppActionBarTitleLight</item>
    </style>
    <style name="AppActionBarTitleDark" parent="@android:style/TextAppearance.Material.Widget.ActionBar.Title">
        <item name="android:textColor">#ffffff</item>
    </style>
    <style name="AppActionBarTitleLight" parent="@android:style/TextAppearance.Material.Widget.ActionBar.Title">
        <item name="android:textColor">#111111</item>
    </style>
</resources>
